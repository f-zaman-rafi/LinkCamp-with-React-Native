{
  "expo": {
    "name": "LinkCamp",
    "slug": "linkcamp-with-react-native",
    "version": "1.0.0",
    "scheme": "linkcamp-with-react-native",
    "web": {
      "favicon": "./assets/logo_linkcamp.png",
      "bundler": "metro"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_linkcamp.png",
        "backgroundColor": "#ffffff"
      }
    }
  }
}
